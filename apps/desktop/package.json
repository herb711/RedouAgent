{
  "name": "redou-agent-desktop",
  "productName": "Redou Agent",
  "version": "0.1.9",
  "private": true,
  "description": "Redou Agent desktop shell",
  "main": "src/main.cjs",
  "scripts": {
    "prebuild": "npm --prefix ../../vendor/hermes/web run build",
    "start": "electron .",
    "build": "electron-builder --win nsis",
    "test": "node --test --test-force-exit --test-reporter=dot tests/*.test.cjs"
  },
  "devDependencies": {
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.redou.agent",
    "productName": "Redou Agent",
    "publish": [
      {
        "provider": "github",
        "owner": "herb711",
        "repo": "RedouAgent"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json",
      "assets/**/*"
    ],
    "asarUnpack": [
      "src/**/*.py"
    ],
    "extraResources": [
      {
        "from": "../../vendor/hermes",
        "to": "vendor/hermes",
        "filter": [
          "**/*",
          "!**/node_modules/**",
          "!**/__pycache__/**",
          "!**/.pytest_cache/**",
          "!**/.mypy_cache/**",
          "!**/.ruff_cache/**",
          "!**/*.pyc",
          "!**/*.pyo",
          "!**/*.egg-info/**",
          "!.env",
          "!.git/**",
          "!web/dist/**",
          "!web/public/ds-assets/**",
          "!web/public/fonts/**",
          "!ui-tui/dist/**",
          "!ui-tui/packages/hermes-ink/dist/**",
          "!website/build/**",
          "!website/out/**",
          "!website/.vitepress/dist/**"
        ]
      }
    ],
    "extraMetadata": {
      "main": "src/main.cjs"
    },
    "win": {
      "artifactName": "Redou-Agent-Setup-${version}.${ext}",
      "icon": "assets/icons/redou-agent.ico",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh",
      "installerIcon": "assets/icons/redou-agent-install.ico",
      "uninstallerIcon": "assets/icons/redou-agent-install.ico"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
