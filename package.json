{
  "name": "redou-agent-workspace",
  "version": "0.3.1",
  "private": true,
  "description": "Redou Agent workspace. Hermes runtime is vendored under vendor/hermes for upstream sync.",
  "scripts": {
    "desktop": "npm --prefix apps/desktop start",
    "desktop:build": "npm --prefix apps/desktop run build",
    "desktop:build:win": "npm --prefix apps/desktop run build:win",
    "desktop:build:linux": "npm --prefix apps/desktop run build:linux",
    "desktop:test": "node --test --test-force-exit --test-reporter=dot ./apps/desktop/tests/*.test.cjs",
    "web:dev": "npm --prefix vendor/hermes/web run dev",
    "web:build": "npm --prefix vendor/hermes/web run build",
    "tui:dev": "npm --prefix vendor/hermes/ui-tui run dev",
    "tui:build": "npm --prefix vendor/hermes/ui-tui run build",
    "check:generated": "python scripts/check-generated-dirty.py",
    "export:clean": "python scripts/export-clean.py --output RedouAgent-clean.zip",
    "smoke": "python scripts/smoke-test.py",
    "hermes:test:redou": "python -m pytest -q -o addopts= vendor/hermes/tests/hermes_cli/test_redou_context_contract.py",
    "check:paths": "python scripts/check-path-contract.py",
    "check:all": "npm run check:paths && npm run check:generated && npm run smoke"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
